{
  "name": "@vibeseek/desktop",
  "version": "1.0.0",
  "private": true,
  "description": "VibeSeek — DeepSeek-native vibe coding desktop client",
  "author": "qjg",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.node.json --noEmit && tsc -p tsconfig.web.json --noEmit",
    "rebuild-native": "electron-builder install-app-deps",
    "postinstall": "electron-builder install-app-deps",
    "pack": "electron-vite build && electron-builder --dir",
    "dist": "electron-vite build && electron-builder"
  },
  "dependencies": {
    "better-sqlite3": "^11.8.0"
  },
  "devDependencies": {
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "@types/better-sqlite3": "^7.6.0",
    "@types/node": "^22.0.0",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vibeseek/core": "workspace:*",
    "@vitejs/plugin-react": "^4.3.0",
    "electron": "^35.0.0",
    "electron-builder": "^25.0.0",
    "electron-vite": "^2.3.0",
    "i18next": "^24.0.0",
    "lucide-react": "^1.17.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "react-i18next": "^15.0.0",
    "vite": "^6.0.0",
    "vitest": "^3.0.0"
  }
}
