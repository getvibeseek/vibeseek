{
  "name": "vibeseek",
  "version": "0.0.1",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "pnpm -F @vibeseek/desktop dev",
    "build": "pnpm -r build",
    "lint": "eslint .",
    "test": "pnpm -r test",
    "eval": "pnpm -F @vibeseek/core exec vitest run src/evals/evals.test.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "eslint": "^9.0.0",
    "eslint-config-prettier": "^9.0.0",
    "eslint-plugin-i18next": "^6.0.0",
    "eslint-plugin-react": "^7.37.0",
    "eslint-plugin-react-hooks": "^5.0.0",
    "globals": "^15.0.0",
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prettier": "^3.0.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.0.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,yaml}": [
      "prettier --write"
    ]
  }
}
